{
  "name": "@stint/gui",
  "version": "1.0.0",
  "description": "Stint GUI — an Electron tray app and main window over @stint/core, an equal surface to the tt CLI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc --build tsconfig.main.json",
    "start": "electron .",
    "pack": "electron-builder --mac --linux --config electron-builder.yml",
    "pack:smoke": "electron-builder --linux dir --config electron-builder.yml"
  },
  "dependencies": {
    "@stint/core": "1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8"
  }
}
